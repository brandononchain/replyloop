# ─────────────────────────────────────────────────────────────────
# Replyloop MCP Server — environment configuration
# ─────────────────────────────────────────────────────────────────

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Run mode ---
# false → open / demo mode (no auth, demo adapter)
# true  → hosted mode (requires API key, resolves org from Supabase)
HOSTED_MODE=false

# --- Supabase (required when HOSTED_MODE=true) ---
SUPABASE_URL=https://mewkmvttpbspgfidjewa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Business Profile OAuth (only when wiring real platform) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://replyloop.dev/api/connections/google/callback

# --- Demo mode (used by stdio path) ---
DEMO_MODE=true
